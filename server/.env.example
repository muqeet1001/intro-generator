# Copy to .env (local) or set these in your host's environment settings (deploy).

# ── Server ──────────────────────────────────────────────
PORT=5000

# ── Storage ─────────────────────────────────────────────
DB_MODE=mongo
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/intro_generator?retryWrites=true&w=majority
DATA_FILE=./data/leads.json

# ── AI ──────────────────────────────────────────────────
# Primary: Claude via the Anthropic Messages API (Futura gateway or Anthropic).
ANTHROPIC_BASE_URL=https://nqiyoamhphztywolejaq.supabase.co/functions/v1/gateway/anthropic
ANTHROPIC_API_KEY=pk_live_your_gateway_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
# Fallback OpenAI-compatible endpoint (local Ollama in dev; harmless in cloud).
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=
AI_MODEL=gemma4:e4b
# Legacy Lovable MCP (leave blank — no longer used for generation).
LOVABLE_MCP_URL=

# ── Search-as-you-type ──────────────────────────────────
FIRECRAWL_API_KEY=fc-your-key-here
SEARCH_SITE_FILTER=site:linkedin.com/in

# ── Email (Resend) — makes the "Email me" button actually deliver ───
# Get a key at resend.com; verify a sending domain (e.g. svtouch.com) and use
# an address on it. Leave blank to just save the lead without emailing.
RESEND_API_KEY=
MAIL_FROM=SVTouch Intro Generator <intros@svtouch.com>

# ── Admin protection (recommended for public deploys) ───
# When set, /admin and /api/admin require HTTP Basic auth (any username + this password).
ADMIN_PASSWORD=
